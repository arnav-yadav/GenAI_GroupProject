# Copy to .env and fill in. Never commit .env.

# Gemini (free) — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# Qdrant — local Docker (default) or Qdrant Cloud (free tier)
#   Local:  docker run -p 6333:6333 qdrant/qdrant
#   Cloud:  set the cluster URL + api key from https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# QDRANT_COLLECTION=aria_guidelines

# Backend port (frontend dev proxy expects 8787)
PORT=8787
